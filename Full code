class FileNode:
    def __init__(self):
        # Maps directory/file name -> FileNode
        self.children = {}
        self.is_file = False
        self.content = ""

class FileSystem:
    def __init__(self):
        self.root = FileNode()

    def _parse_path(self, path: str) -> list[str]:
        # Helper to split path into components, filtering out empty strings
        if path == "/":
            return []
        return path.split("/")[1:]

    def _traverse(self, path: str, create_missing: bool = False) -> FileNode:
        # Helper to navigate the tree. Can implicitly create directories.
        components = self._parse_path(path)
        curr = self.root
        
        for comp in components:
            if comp not in curr.children:
                if create_missing:
                    curr.children[comp] = FileNode()
                else:
                    return None
            curr = curr.children[comp]
        return curr

    def ls(self, path: str) -> list[str]:
        node = self._traverse(path)
        if not node:
            return []
        
        # Rule 1: If path is a file, return just the file name
        if node.is_file:
            return [path.split("/")[-1]]
            
        # Rule 2: If directory, return sorted names of contents
        return sorted(node.children.keys())

    def mkdir(self, path: str) -> None:
        self._traverse(path, create_missing=True)

    def addContentToFile(self, filePath: str, content: str) -> None:
        # Implicitly creates directory path up to the file
        node = self._traverse(filePath, create_missing=True)
        node.is_file = True
        node.content += content  # Appends if already exists

    def readContentFromFile(self, filePath: str) -> str:
        node = self._traverse(filePath)
        return node.content if node and node.is_file else ""
